# Git Ignore for Emotion Engine v8.0

# Environment files with secrets
.env
.env.*
!.env.example
.env.backup
.env.local
.env.*.local
*.env

# Runtime configs with secrets
.pipeline-runtime.yaml
*.runtime.yaml
.runtime-config.json

# Output directories
/output/
.cache/
dist/

# Dependencies
node_modules/

# Cache and Temporary Files
*.tmp
*.temp

# Logs
logs/
*.log
npm-debug.log*

# OS Files
.DS_Store
Thumbs.db

# Editor Files
.vscode/
.idea/
*.swp
*.swo
