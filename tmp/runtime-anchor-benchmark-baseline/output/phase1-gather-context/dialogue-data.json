{
  "dialogue_segments": [
    {
      "start": 0,
      "end": 3,
      "speaker": "Speaker 1",
      "speaker_id": "spk_001",
      "text": "They want you afraid.",
      "confidence": 0.95,
      "index": 0
    },
    {
      "start": 3,
      "end": 6,
      "speaker": "Speaker 1",
      "speaker_id": "spk_001",
      "text": "Fear makes you easier to control.",
      "confidence": 0.95,
      "index": 1
    },
    {
      "start": 6,
      "end": 8,
      "speaker": "Speaker 1",
      "speaker_id": "spk_001",
      "text": "It's time to wake up.",
      "confidence": 0.95,
      "index": 2
    },
    {
      "start": 8,
      "end": 12,
      "speaker": "Speaker 2",
      "speaker_id": "spk_002",
      "text": "Your streets shall once again run red with your blood.",
      "confidence": 0.95,
      "index": 3
    },
    {
      "start": 12,
      "end": 16,
      "speaker": "Speaker 3",
      "speaker_id": "spk_003",
      "text": "Raul Menendez ignited global unrest on an unprecedented scale.",
      "confidence": 0.95,
      "index": 4
    },
    {
      "start": 16,
      "end": 18,
      "speaker": "Speaker 4",
      "speaker_id": "spk_004",
      "text": "Menendez is a terrorist.",
      "confidence": 0.95,
      "index": 5
    },
    {
      "start": 18,
      "end": 22,
      "speaker": "Speaker 5",
      "speaker_id": "spk_005",
      "text": "We're bringing peace and security to the world.",
      "confidence": 0.95,
      "index": 6
    },
    {
      "start": 22,
      "end": 25,
      "speaker": "Speaker 6",
      "speaker_id": "spk_006",
      "text": "He refuses to let me go.",
      "confidence": 0.95,
      "index": 7
    },
    {
      "start": 25,
      "end": 30,
      "speaker": "Speaker 7",
      "speaker_id": "spk_007",
      "text": "Stop looking backwards, David. What matters is what you do next.",
      "confidence": 0.95,
      "index": 8
    },
    {
      "start": 30,
      "end": 34,
      "speaker": "Speaker 6",
      "speaker_id": "spk_006",
      "text": "A lot of people counting on us for answers.",
      "confidence": 0.95,
      "index": 9
    },
    {
      "start": 34,
      "end": 36,
      "speaker": "Speaker 8",
      "speaker_id": "spk_008",
      "text": "Spectre One report.",
      "confidence": 0.95,
      "index": 10
    },
    {
      "start": 36,
      "end": 38,
      "speaker": "Speaker 8",
      "speaker_id": "spk_008",
      "text": "Need a sitrep.",
      "confidence": 0.95,
      "index": 11
    },
    {
      "start": 38,
      "end": 40,
      "speaker": "Speaker 6",
      "speaker_id": "spk_006",
      "text": "This isn't real.",
      "confidence": 0.95,
      "index": 12
    },
    {
      "start": 40,
      "end": 42,
      "speaker": "Speaker 9",
      "speaker_id": "spk_009",
      "text": "The hell it ain't!",
      "confidence": 0.95,
      "index": 13
    },
    {
      "start": 42,
      "end": 50,
      "speaker": "Speaker 10",
      "speaker_id": "spk_010",
      "text": "Obey your master, master. Come crawling faster, faster. Master, master.",
      "confidence": 0.9,
      "index": 14
    },
    {
      "start": 50,
      "end": 52,
      "speaker": "Speaker 11",
      "speaker_id": "spk_011",
      "text": "Pull it together, man.",
      "confidence": 0.95,
      "index": 15
    },
    {
      "start": 52,
      "end": 56,
      "speaker": "Speaker 2",
      "speaker_id": "spk_002",
      "text": "So eager to leave, David.",
      "confidence": 0.95,
      "index": 16
    },
    {
      "start": 56,
      "end": 60,
      "speaker": "Speaker 2",
      "speaker_id": "spk_002",
      "text": "Killing the man is a hell of a lot easier than killing the idea.",
      "confidence": 0.95,
      "index": 17
    },
    {
      "start": 60,
      "end": 64,
      "speaker": "Speaker 12",
      "speaker_id": "spk_012",
      "text": "You were never cut out to be a Mason.",
      "confidence": 0.95,
      "index": 18
    },
    {
      "start": 64,
      "end": 68,
      "speaker": "Speaker 6",
      "speaker_id": "spk_006",
      "text": "No more games. This ends now.",
      "confidence": 0.95,
      "index": 19
    },
    {
      "start": 68,
      "end": 75,
      "speaker": "Speaker 10",
      "speaker_id": "spk_010",
      "text": "Obey your master, master.",
      "confidence": 0.9,
      "index": 20
    },
    {
      "start": 75,
      "end": 80,
      "speaker": "Speaker 13",
      "speaker_id": "spk_013",
      "text": "Get the Reznov Challenge Pack when you pre-order now.",
      "confidence": 0.95,
      "index": 21
    }
