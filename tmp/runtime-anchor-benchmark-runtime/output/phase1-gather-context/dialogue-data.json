      "index": 1
    },
    {
      "start": 7.5,
      "end": 10,
      "speaker": "Speaker 1",
      "speaker_id": "spk_001",
      "text": "It's time to wake up.",
      "confidence": 0.94,
      "index": 2
    },
    {
      "start": 10.5,
      "end": 16,
      "speaker": "Speaker 2",
      "speaker_id": "spk_002",
      "text": "Your streets shall once again run red with your blood.",
      "confidence": 0.91,
      "index": 3
    },
    {
      "start": 16.5,
      "end": 21.5,
      "speaker": "Speaker 3",
      "speaker_id": "spk_003",
      "text": "Raul Menendez ignited global unrest on an unprecedented scale.",
      "confidence": 0.93,
      "index": 4
    },
    {
      "start": 22,
      "end": 27,
      "speaker": "Speaker 1",
      "speaker_id": "spk_001",
      "text": "Menendez is a terrorist. We're bringing peace and security to the world.",
      "confidence": 0.91,
      "index": 5
    },
    {
      "start": 28,
      "end": 31,
      "speaker": "Speaker 4",
      "speaker_id": "spk_004",
      "text": "He refuses to let me go.",
      "confidence": 0.89,
      "index": 6
    },
    {
      "start": 31.5,
      "end": 36,
      "speaker": "Speaker 5",
      "speaker_id": "spk_005",
      "text": "Stop looking backwards, David. What matters is what you do next.",
      "confidence": 0.94,
      "index": 7
    },
    {
      "start": 37,
      "end": 40.5,
      "speaker": "Speaker 4",
      "speaker_id": "spk_004",
      "text": "Lot of people counting on us for answers.",
      "confidence": 0.92,
      "index": 8
    },
    {
      "start": 58,
      "end": 60.5,
      "speaker": "Speaker 6",
      "speaker_id": "spk_006",
      "text": "Spectre One, report.",
      "confidence": 0.88,
      "index": 9
    },
    {
      "start": 61,
      "end": 63,
      "speaker": "Speaker 6",
      "speaker_id": "spk_006",
      "text": "Need a sitrep.",
      "confidence": 0.87,
      "index": 10
    },
    {
      "start": 82,
      "end": 84.5,
      "speaker": "Speaker 4",
      "speaker_id": "spk_004",
      "text": "This isn't real.",
      "confidence": 0.93,
      "index": 11
    },
    {
      "start": 84.5,
      "end": 87,
      "speaker": "Speaker 7",
      "speaker_id": "spk_007",
      "text": "The hell it isn't!",
      "confidence": 0.94,
      "index": 12
    },
    {
      "start": 116,
      "end": 118.5,
      "speaker": "Speaker 5",
      "speaker_id": "spk_005",
      "text": "Pull it together, man!",
      "confidence": 0.91,
      "index": 13
    },
    {
      "start": 119.5,
      "end": 127,
      "speaker": "Speaker 2",
      "speaker_id": "spk_002",
      "text": "So eager to leave, David. Killing the man is a hell of a lot easier than killing the idea.",
      "confidence": 0.92,
      "index": 14
    },
    {
      "start": 128,
      "end": 131.5,
      "speaker": "Speaker 2",
      "speaker_id": "spk_002",
      "text": "You were never cut out to be a Mason.",
      "confidence": 0.93,
      "index": 15
    },
    {
      "start": 132.5,
      "end": 136,
      "speaker": "Speaker 4",
      "speaker_id": "spk_004",
      "text": "No more games. This ends now.",
