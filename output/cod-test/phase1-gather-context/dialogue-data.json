{
  "dialogue_segments": [
    {
      "start": 0,
      "end": 1.2,
      "speaker": "Speaker 1",
      "speaker_id": "spk_001",
      "text": "They want you afraid.",
      "confidence": 0.9,
      "index": 0
    },
    {
      "start": 1.2,
      "end": 3.5,
      "speaker": "Speaker 1",
      "speaker_id": "spk_001",
      "text": "Fear makes you easier to control.",
      "confidence": 0.9,
      "index": 1
    },
    {
      "start": 3.5,
      "end": 5,
      "speaker": "Speaker 1",
      "speaker_id": "spk_001",
      "text": "It's time to wake up.",
      "confidence": 0.9,
      "index": 2
    },
    {
      "start": 5,
      "end": 9,
      "speaker": "Speaker 2",
      "speaker_id": "spk_002",
      "text": "Your streets shall once again run red with your blood.",
      "confidence": 0.95,
      "index": 3
    },
    {
      "start": 9,
      "end": 13,
      "speaker": "Speaker 3",
      "speaker_id": "spk_003",
      "text": "Raul Menendez ignited global unrest on an unprecedented scale.",
      "confidence": 0.95,
      "index": 4
    },
    {
      "start": 13,
      "end": 15,
      "speaker": "Speaker 4",
      "speaker_id": "spk_004",
      "text": "Menendez is a terrorist.",
      "confidence": 0.9,
      "index": 5
    },
    {
      "start": 15,
      "end": 18,
      "speaker": "Speaker 4",
      "speaker_id": "spk_004",
      "text": "We're bringing peace and security to the world.",
      "confidence": 0.9,
      "index": 6
    },
    {
      "start": 18,
      "end": 20,
      "speaker": "Speaker 5",
      "speaker_id": "spk_005",
      "text": "He refuses to let me go.",
      "confidence": 0.85,
      "index": 7
    },
    {
      "start": 20,
      "end": 23,
      "speaker": "Speaker 6",
      "speaker_id": "spk_006",
      "text": "Stop looking backwards, David. What matters is what we do next.",
      "confidence": 0.9,
      "index": 8
    },
    {
      "start": 23,
      "end": 25,
      "speaker": "Speaker 5",
      "speaker_id": "spk_005",
      "text": "A lot of people counting on us for answers.",
      "confidence": 0.85,
      "index": 9
    },
    {
      "start": 90,
      "end": 92,
      "speaker": "Speaker 7",
      "speaker_id": "spk_007",
      "text": "Spectre One report.",
      "confidence": 0.8,
      "index": 10
    },
    {
      "start": 92,
      "end": 94,
      "speaker": "Speaker 7",
      "speaker_id": "spk_007",
      "text": "Need a sitrep.",
      "confidence": 0.8,
      "index": 11
    },
    {
      "start": 94,
      "end": 96,
      "speaker": "Speaker 5",
      "speaker_id": "spk_005",
      "text": "This isn't real.",
      "confidence": 0.85,
      "index": 12
    },
    {
      "start": 96,
      "end": 97,
      "speaker": "Speaker 8",
      "speaker_id": "spk_008",
      "text": "The hell it ain't!",
      "confidence": 0.85,
      "index": 13
    },
    {
      "start": 130,
      "end": 132,
      "speaker": "Speaker 8",
      "speaker_id": "spk_008",
      "text": "Pull it together, man!",
      "confidence": 0.85,
      "index": 14
    },
    {
      "start": 132,
      "end": 134,
      "speaker": "Speaker 9",
      "speaker_id": "spk_009",
      "text": "So eager to leave, David.",
      "confidence": 0.9,
      "index": 15
    },
    {
      "start": 134,
      "end": 138,
      "speaker": "Speaker 9",
      "speaker_id": "spk_009",
      "text": "Killing a man is a hell of a lot easier than killing an idea.",
      "confidence": 0.9,
      "index": 16
    },
    {
      "start": 138,
      "end": 140,
      "speaker": "Speaker 4",
      "speaker_id": "spk_004",
      "text": "You were never cut out to be a Mason.",
      "confidence": 0.9,
      "index": 17
    },
    {
      "start": 140,
      "end": 140.04,
      "speaker": "Speaker 5",
      "speaker_id": "spk_005",
      "text": "No more games. This ends now.",
      "confidence": 0.85,
      "index": 18
    }
  ],
