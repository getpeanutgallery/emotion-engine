{
  "dialogue_segments": [
    {
      "speaker": "Speaker 1",
      "speaker_id": "spk_001",
      "text": "They want you afraid.",
      "confidence": 0.7,
      "index": 0
    },
    {
      "speaker": "Speaker 1",
      "speaker_id": "spk_001",
      "text": "Fear makes you easier to control.",
      "confidence": 0.7,
      "index": 1
    },
    {
      "speaker": "Speaker 1",
      "speaker_id": "spk_001",
      "text": "It's time to wake up.",
      "confidence": 0.7,
      "index": 2
    },
    {
      "speaker": "Speaker 2",
      "speaker_id": "spk_002",
      "text": "Your streets shall once again run red with your blood.",
      "confidence": 0.7,
      "index": 3
    },
    {
      "speaker": "Speaker 3",
      "speaker_id": "spk_003",
      "text": "Raul Menendez ignited global unrest on an unprecedented scale.",
      "confidence": 0.7,
      "index": 4
    },
    {
      "speaker": "Speaker 4",
      "speaker_id": "spk_004",
      "text": "Menendez is a terrorist.",
      "confidence": 0.7,
      "index": 5
    },
    {
      "speaker": "Speaker 5",
      "speaker_id": "spk_005",
      "text": "We're bringing peace and security to the world.",
      "confidence": 0.7,
      "index": 6
    },
    {
      "speaker": "Speaker 6",
      "speaker_id": "spk_006",
      "text": "He refuses to let me go.",
      "confidence": 0.7,
      "index": 7
    },
    {
      "speaker": "Speaker 7",
      "speaker_id": "spk_007",
      "text": "Stop looking backwards, David, but matters is what we do next.",
      "confidence": 0.7,
      "index": 8
    },
    {
      "speaker": "Speaker 7",
      "speaker_id": "spk_007",
      "text": "A lot of people counting on us for answers.",
      "confidence": 0.7,
      "index": 9
    },
    {
      "speaker": "Speaker 8",
      "speaker_id": "spk_008",
      "text": "Spectre Wolf report.",
      "confidence": 0.7,
      "index": 10
    },
    {
      "speaker": "Speaker 8",
      "speaker_id": "spk_008",
      "text": "Need a sitrep.",
      "confidence": 0.7,
      "index": 11
    },
    {
      "speaker": "Speaker 9",
      "speaker_id": "spk_009",
      "text": "This isn't real.",
      "confidence": 0.7,
      "index": 12
    },
    {
      "speaker": "Speaker 10",
      "speaker_id": "spk_010",
      "text": "The hell it ain't!",
      "confidence": 0.7,
      "index": 13
    },
    {
      "speaker": "Speaker 11",
      "speaker_id": "spk_011",
      "text": "Obey your master.",
      "confidence": 0.7,
      "index": 14
    },
    {
      "speaker": "Speaker 11",
      "speaker_id": "spk_011",
      "text": "Come crawling faster.",
      "confidence": 0.7,
      "index": 15
    },
    {
      "speaker": "Speaker 11",
      "speaker_id": "spk_011",
      "text": "Master, master.",
      "confidence": 0.7,
      "index": 16
    },
    {
      "speaker": "Speaker 11",
      "speaker_id": "spk_011",
      "text": "Just call my name, 'cause I'll hear you scream.",
      "confidence": 0.7,
      "index": 17
    },
    {
      "speaker": "Speaker 11",
      "speaker_id": "spk_011",
      "text": "Master, master.",
      "confidence": 0.7,
      "index": 18
    },
    {
      "speaker": "Speaker 7",
      "speaker_id": "spk_007",
      "text": "Pull it together, man.",
      "confidence": 0.7,
      "index": 19
    },
    {
      "speaker": "Speaker 12",
      "speaker_id": "spk_012",
      "text": "So eager to leave, David.",
      "confidence": 0.7,
      "index": 20
    },
    {
      "speaker": "Speaker 12",
      "speaker_id": "spk_012",
      "text": "Killing a man is a hell of a lot easier than killing an idea.",
      "confidence": 0.7,
      "index": 21
    },
    {
      "speaker": "Speaker 12",
      "speaker_id": "spk_012",
      "text": "You were never cut out to be a Mason.",
      "confidence": 0.7,
      "index": 22
    },
    {
      "speaker": "Speaker 6",
      "speaker_id": "spk_006",
      "text": "No more games. This ends now.",
      "confidence": 0.7,
      "index": 23
    },
    {
      "speaker": "Speaker 11",
      "speaker_id": "spk_011",
      "text": "Obey your master.",
      "confidence": 0.7,
      "index": 24
    },
    {
      "speaker": "Speaker 13",
      "speaker_id": "spk_013",
      "text": "Get the Reznov challenge pack when you pre-order now.",
      "confidence": 0.7,
      "index": 25
    }
  ],
