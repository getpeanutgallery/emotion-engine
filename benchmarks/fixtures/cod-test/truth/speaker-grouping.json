    {
      "segment_index": 3,
      "speaker_group_key": "first_segment_003",
      "source_speaker_id": "spk_003",
      "label": "Speaker 3",
      "text": "Raul Menendez ignited global unrest on an unprecedented scale."
    },
    {
      "segment_index": 4,
      "speaker_group_key": "first_segment_000",
      "source_speaker_id": "spk_001",
      "label": "Speaker 1",
      "text": "Menendez is a terrorist."
    },
    {
      "segment_index": 5,
      "speaker_group_key": "first_segment_000",
      "source_speaker_id": "spk_001",
      "label": "Speaker 1",
      "text": "We're bringing peace and security to the world."
    },
    {
      "segment_index": 6,
      "speaker_group_key": "first_segment_006",
      "source_speaker_id": "spk_006",
      "label": "Speaker 6",
      "text": "He refuses to let me go."
    },
    {
      "segment_index": 7,
      "speaker_group_key": "first_segment_007",
      "source_speaker_id": "spk_007",
      "label": "Speaker 7",
      "text": "Stop looking backwards, David. What matters is what we do next."
    },
    {
      "segment_index": 8,
      "speaker_group_key": "first_segment_006",
      "source_speaker_id": "spk_006",
      "label": "Speaker 6",
      "text": "A lot of people counting on us for answers."
    },
    {
      "segment_index": 9,
      "speaker_group_key": "first_segment_002",
      "source_speaker_id": "spk_002",
      "label": "Speaker 2",
      "text": "You shall know fear."
    },
    {
      "segment_index": 10,
      "speaker_group_key": "first_segment_010",
      "source_speaker_id": "spk_008",
      "label": "Speaker 8",
      "text": "Specter one, report."
    },
    {
      "segment_index": 11,
      "speaker_group_key": "first_segment_010",
      "source_speaker_id": "spk_008",
      "label": "Speaker 8",
      "text": "Need a sitrep."
    },
    {
      "segment_index": 12,
      "speaker_group_key": "first_segment_012",
      "source_speaker_id": "spk_009",
      "label": "Speaker 9",
      "text": "This isn't real."
    },
    {
      "segment_index": 13,
      "speaker_group_key": "first_segment_013",
      "source_speaker_id": "spk_010",
      "label": "Speaker 10",
      "text": "The hell it ain't!"
    },
    {
      "segment_index": 14,
      "speaker_group_key": "first_segment_014",
      "source_speaker_id": "spk_012",
      "label": "Speaker 12",
      "text": "Pull it together, man!"
    },
    {
      "segment_index": 15,
      "speaker_group_key": "first_segment_002",
      "source_speaker_id": "spk_002",
      "label": "Speaker 2",
      "text": "So eager to leave David."
    },
    {
      "segment_index": 16,
      "speaker_group_key": "first_segment_016",
      "source_speaker_id": "spk_013",
      "label": "Speaker 13",
      "text": "Killing a man is a hell of a lot easier than killing the idea."
    },
    {
      "segment_index": 17,
      "speaker_group_key": "first_segment_017",
      "source_speaker_id": "spk_015",
      "label": "Speaker 15",
      "text": "You were never cut out to be a Mason."
    },
    {
      "segment_index": 18,
      "speaker_group_key": "first_segment_006",
      "source_speaker_id": "spk_006",
      "label": "Speaker 6",
      "text": "No more games! This ends now."
    },
