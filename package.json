{
  "name": "emotion-engine",
  "version": "8.0.0",
  "type": "commonjs",
  "description": "Modular, tool-agnostic AI workflow engine for multi-modal emotion analysis",
  "main": "server/run-pipeline.cjs",
  "bin": {
    "emotion-engine": "./bin/run-pipeline.js"
  },
  "scripts": {
    "pipeline": "node server/run-pipeline.cjs",
    "test": "node --test test/**/*.test.js",
    "test:providers:check": "node -e \"const twin=require('./test/helpers/digital-twin-preflight.cjs'); twin.applyDefaultDigitalTwinEnv(); twin.preflightDigitalTwin()\"",
    "test:validate-json": "node test-validate-json.cjs",
    "validate-configs": "node validate-configs.cjs",
    "analyze:recent-errors": "node scripts/analyze-recent-run-errors.cjs",
    "check:secrets": "node scripts/check-no-secrets.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "ai-providers": "github:getpeanutgallery/ai-providers#79838d5cf1d3acf77cf8f9b0ac5823a43085d1ec",
    "axios": "^1.13.6",
    "cast": "git+ssh://git@github.com/getpeanutgallery/cast.git#main",
    "digital-twin-core": "link:../digital-twin-core",
    "dotenv": "^17.3.1",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "goals": "git+ssh://git@github.com/getpeanutgallery/goals.git#main",
    "js-yaml": "^4.1.0",
    "retry-strategy": "git+ssh://git@github.com/getpeanutgallery/retry-strategy.git#main",
    "tools": "git+ssh://git@github.com/getpeanutgallery/tools.git#main"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "emotion-analysis",
    "multi-modal",
    "pipeline",
    "workflow"
  ],
  "author": "OpenTruth",
  "license": "MIT"
}
