# Emotion Engine - Example Environment Configuration
#
# 1) Copy this file to .env:
#      cp .env.example .env
#
# 2) Fill in the values you need (never commit real secrets).

# ---------------------------------------------------------------------------
# AI provider keys (required for live calls; tests may use DIGITAL_TWIN_*)
# ---------------------------------------------------------------------------

# Canonical key used by the engine (some providers also support provider-specific keys)
AI_API_KEY=

# Optional provider-specific keys (if you prefer):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Digital Twin (cassette replay/record) - used by provider/integration tests
# ---------------------------------------------------------------------------

# Mode examples (depends on your digital-twin setup): replay | record | passthrough
# DIGITAL_TWIN_MODE=replay

# Path to a digital twin pack:
#   test/fixtures/digital-twin-emotion-engine-providers
# DIGITAL_TWIN_PACK=

# Cassette name (without .json). The file is expected at:
#   $DIGITAL_TWIN_PACK/cassettes/$DIGITAL_TWIN_CASSETTE.json
# DIGITAL_TWIN_CASSETTE=providers

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# LOG_LEVEL=debug
# LOG_FILE=logs/emotion-engine.log

# ---------------------------------------------------------------------------
# Session / runtime
# ---------------------------------------------------------------------------

# SESSION_ID=
# MODELS_CONFIG_PATH=

# ---------------------------------------------------------------------------
# Storage (local filesystem or S3)
# ---------------------------------------------------------------------------

# STORAGE_PROVIDER=local-fs
# STORAGE_BASE_DIR=output

# S3 settings (only needed if STORAGE_PROVIDER=aws-s3)
# S3_BUCKET=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional (e.g., when running in AWS with web identity)
# AWS_WEB_IDENTITY_TOKEN_FILE=
